---
import { NAV, NAV_MIN, LANGS, UI, type Lang } from '../data/site';

interface Props {
  lang: Lang;
  alts: Record<Lang, string>;
}
const { lang, alts } = Astro.props;

const current = Astro.url.pathname;
const t = UI[lang];

const items =
  lang === 'tr' || lang === 'en'
    ? NAV.map((n) => n[lang])
    : NAV_MIN[lang];

const homeHref = LANGS.find((l) => l.code === lang)!.home;

const norm = (p: string) => (p !== '/' ? p.replace(/\/$/, '') : '/');
const isCurrent = (href: string) =>
  href.startsWith('#') ? false : norm(current) === norm(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      Uzm. Dr. Birkan Alaycı <span>· {t.specialty}</span>
    </a>

    <button
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label={t.menu}
      id="menu-toggle"
    >
      ☰
    </button>

    <nav class="nav" id="primary-nav" aria-label={t.mainMenu}>
      {
        items.map((item) => (
          <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <label class="lang-select-wrap">
        <span class="sr-only">{t.langAria}</span>
        <select class="lang-select" id="lang-select" aria-label={t.langAria}>
          {
            LANGS.map((l) => (
              <option value={alts[l.code]} selected={lang === l.code}>
                {l.label} · {l.native}
              </option>
            ))
          }
        </select>
      </label>
      <a class="btn btn-primary btn-sm cta-book" href={t.contactHref}>{t.cta}</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('primary-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
  const sel = document.getElementById('lang-select');
  if (sel) {
    sel.addEventListener('change', (e) => {
      const v = (e.target as HTMLSelectElement).value;
      if (v) window.location.href = v;
    });
  }
</script>
