---
import { HEALTH_CARDS, FAQ_CARDS, VIDEOS } from '../data/notes';

interface Props {
  lang: 'tr' | 'en';
}
const { lang } = Astro.props;

const t = {
  tr: {
    cardsTitle: 'Sağlık Kartları',
    cardsLead: 'Tek bakışta okunan, kanıta dayalı kısa notlar.',
    hint: 'Karta dokun → yeni kart',
    videosTitle: 'Mini Videolar',
    videosSoon:
      'Kısa, anlaşılır bilgilendirme videoları yakında bu bölümde yer alacak.',
    soonBadge: 'Yakında',
    disclaimer:
      'Bu içerikler genel bilgilendirme amaçlıdır ve kişisel tıbbi tavsiye yerine geçmez. Şikâyetleriniz için lütfen hekiminize danışın.',
  },
  en: {
    cardsTitle: 'Health Cards',
    cardsLead: 'Evidence-based notes, readable at a glance.',
    hint: 'Tap the card → new card',
    videosTitle: 'Mini Videos',
    videosSoon: 'Short, clear explainer videos will appear here soon.',
    soonBadge: 'Soon',
    disclaimer:
      'This content is for general information only and is not a substitute for personal medical advice. Please consult your physician for your concerns.',
  },
}[lang];

// İstemciye verilecek kart listesi. TR'de zengin SSS havuzu (kaynaklı),
// EN'de mevcut iki dilli kısa kartlar.
const sourceLabel = lang === 'tr' ? 'Kaynak: ' : 'Source: ';
const cards =
  lang === 'tr'
    ? FAQ_CARDS.map((c) => ({
        tag: c.kategori,
        title: c.soru,
        body: c.cevap,
        source: c.kaynaklar.join(' · '),
      }))
    : HEALTH_CARDS.map((c) => ({
        tag: c.tag.en,
        title: c.title.en,
        body: c.body.en,
        source: '',
      }));
const total = cards.length;
const first = cards[0];

// FAQPage yapısal verisi — tüm soru/cevaplar Google'a (zengin sonuç şansı).
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: cards.map((c) => ({
    '@type': 'Question',
    name: c.title,
    acceptedAnswer: { '@type': 'Answer', text: c.body },
  })),
};
---

<h2>{t.cardsTitle}</h2>
<p class="muted">{t.cardsLead}</p>

<div class="flashcard-stage mt-3">
  <div
    class="flashcard"
    id="flashcard"
    role="button"
    tabindex="0"
    aria-label={t.hint}
  >
    <span class="ktag" id="fc-tag">{first.tag}</span>
    <h3 id="fc-title">{first.title}</h3>
    <p id="fc-body" aria-live="polite">{first.body}</p>
    <p class="fc-source small muted" id="fc-source" hidden={!first.source}>
      {first.source ? sourceLabel + first.source : ''}
    </p>
    <span class="flashcard-hint">{t.hint}</span>
  </div>
  <p class="flashcard-count small muted">
    <span id="fc-index">1</span> / {total}
  </p>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

<h2 class="mt-4">{t.videosTitle}</h2>
{
  VIDEOS.length === 0 ? (
    <div class="note mt-2">
      {t.videosSoon}
      <span class="pending">{t.soonBadge}</span>
    </div>
  ) : (
    <div class="video-grid mt-3">
      {VIDEOS.map((v) => (
        <figure class="vthumb">
          <div class="vframe">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${v.youtube}`}
              title={v.title[lang]}
              loading="lazy"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
          <figcaption>{v.title[lang]}</figcaption>
        </figure>
      ))}
    </div>
  )
}

<p class="small muted mt-4">{t.disclaimer}</p>

<script define:vars={{ cards, sourceLabel }}>
  const el = document.getElementById('flashcard');
  if (el && cards.length > 1) {
    const tagEl = document.getElementById('fc-tag');
    const titleEl = document.getElementById('fc-title');
    const bodyEl = document.getElementById('fc-body');
    const sourceEl = document.getElementById('fc-source');
    const idxEl = document.getElementById('fc-index');
    let current = -1;

    const show = (i) => {
      const c = cards[i];
      tagEl.textContent = c.tag;
      titleEl.textContent = c.title;
      bodyEl.textContent = c.body;
      if (sourceEl) {
        if (c.source) {
          sourceEl.textContent = sourceLabel + c.source;
          sourceEl.hidden = false;
        } else {
          sourceEl.textContent = '';
          sourceEl.hidden = true;
        }
      }
      if (idxEl) idxEl.textContent = String(i + 1);
      current = i;
    };

    const nextRandom = () => {
      let i = current;
      while (i === current) i = Math.floor(Math.random() * cards.length);
      el.classList.add('is-flipping');
      window.setTimeout(() => {
        show(i);
        el.classList.remove('is-flipping');
      }, 160);
    };

    // İlk yüklemede rastgele bir kartla başla.
    show(Math.floor(Math.random() * cards.length));

    el.addEventListener('click', nextRandom);
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        nextRandom();
      }
    });
  }
</script>

<style>
  /* Rastgele "flashcard" — tek kart, dokununca yenisi gelir */
  .flashcard-stage {
    max-width: 38rem;
  }
  .flashcard {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.6rem 1.7rem;
    box-shadow: var(--shadow);
    cursor: pointer;
    min-height: 12rem;
    transition: opacity 0.16s ease, transform 0.16s ease,
      border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .flashcard:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 28px rgba(28, 43, 51, 0.1);
  }
  .flashcard.is-flipping {
    opacity: 0;
    transform: translateY(8px);
  }
  .flashcard h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    margin: 0.6rem 0 0.5rem;
  }
  .flashcard p {
    font-size: 1.02rem;
    margin: 0;
    color: var(--text-soft);
  }
  .fc-source {
    margin-top: 0.9rem;
    font-style: italic;
    line-height: 1.4;
  }
  .flashcard-hint {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .flashcard-hint::before {
    content: '↻ ';
  }
  .flashcard-count {
    margin-top: 0.75rem;
    text-align: center;
  }
  .ktag {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-deep);
    background: var(--accent-soft);
    border: 1px solid #cfe3e4;
    border-radius: 4px;
    padding: 0.12rem 0.5rem;
  }

  /* Dikey (9:16) mini video ızgarası */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .vthumb {
    margin: 0;
  }
  .vframe {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-soft);
  }
  .vframe iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .vthumb figcaption {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-soft);
    line-height: 1.4;
  }
</style>
