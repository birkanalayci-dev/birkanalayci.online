---
import { NAV, NAV_MIN, SHOW_PERSONAL_PAGE, SITE, UI, type Lang } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = UI[lang];
const isMain = lang === 'tr' || lang === 'en';

const items = isMain ? NAV.map((n) => n[lang as 'tr' | 'en']) : NAV_MIN[lang];
const year = new Date().getFullYear();

const kvkkLabel = lang === 'tr' ? 'KVKK Aydınlatma Metni' : 'Privacy (KVKK)';
const kvkkHref = lang === 'tr' ? '/kvkk/' : '/en/privacy/';
const personalHref = lang === 'tr' ? '/kisisel/' : '/en/personal/';
const personalLabel = lang === 'tr' ? 'Kişisel' : 'Personal';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p style="color:var(--text);font-weight:600;font-family:var(--serif);">{SITE.name}</p>
      <p class="small">{t.specialty} · {t.city}</p>
      <p class="small mt-1"><a href={kvkkHref}>{kvkkLabel}</a></p>
    </div>

    <nav aria-label={t.mainMenu}>
      <ul class="footer-links">
        {items.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        {isMain && SHOW_PERSONAL_PAGE && (
          <li><a href={personalHref} class="muted">{personalLabel}</a></li>
        )}
      </ul>
    </nav>
  </div>

  <div class="container" style="margin-top:1.5rem;">
    <p class="small muted">© {year} {SITE.name}. {t.rights}</p>
  </div>
</footer>
