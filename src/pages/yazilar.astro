---
import Base from '../layouts/Base.astro';
import AppointmentBanner from '../components/AppointmentBanner.astro';
import KnowledgeFeed from '../components/KnowledgeFeed.astro';

const title = 'Sağlık Notları — Uzm. Dr. Birkan Alaycı, İç Hastalıkları';
const description =
  'Uzun makaleler yerine tek bakışta okunan sağlık kartları ve kısa videolar: diyabet, tiroid, tansiyon, metabolik sağlık ve check-up üzerine kanıta dayalı, hasta dostu notlar.';
---

<Base {title} {description} lang="tr" trHref="/yazilar/" enHref="/en/writing/">
  <section class="section">
    <div class="container">
      <div class="prose">
        <p class="eyebrow">Kanıta dayalı kartlar</p>
        <h1>Sağlık kart kütüphanesi</h1>
        <p class="lead mt-2">
          Blog değil, rafine edilmiş bir kütüphane: sık sorulan her soruya kısa,
          kanıta dayalı ve kaynağıyla birlikte tek bir kart. Karta dokununca
          rastgele yenisi gelir.
        </p>
      </div>

      <div class="mt-4">
        <KnowledgeFeed lang="tr" />
      </div>

      <p class="small muted mt-4">Son güncelleme: Haziran 2026</p>
    </div>
  </section>

  <AppointmentBanner lang="tr" />
</Base>
