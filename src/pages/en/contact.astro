---
import Base from '../../layouts/Base.astro';
import { LINKS, PLACEHOLDER_LINKS, CLINIC } from '../../data/site';

const title = 'Contact & Appointments — Birkan Alaycı, MD, Liv Vadistanbul';
const description =
  'Contact and appointments for Birkan Alaycı, MD. Liv Hospital Vadistanbul, Sarıyer / Istanbul. Call center 444 45 48.';

const livHref = PLACEHOLDER_LINKS.livAppointment !== '#' ? PLACEHOLDER_LINKS.livAppointment : LINKS.liv;
---

<Base {title} {description} lang="en" trHref="/iletisim/" enHref="/en/contact/">
  <section class="section">
    <div class="container">
      <div class="prose">
        <p class="eyebrow">Contact & appointments</p>
        <h1>Appointments &amp; contact</h1>
        <p class="lead mt-2">
          Appointment requests are handled through the official channels of Liv
          Hospital Vadistanbul.
        </p>
      </div>

      <div class="grid grid-2 mt-4">
        <div class="card">
          <h2 style="font-size:1.25rem;">Appointments</h2>
          <p class="mt-1">Call the Liv Hospital call center or use the hospital’s official page.</p>
          <p class="mt-2" style="font-size:1.15rem;">
            <strong>Call center:</strong>
            <a href={CLINIC.callCenterTel}>{CLINIC.callCenter}</a>
          </p>
          <p class="small muted">Switchboard: <a href={CLINIC.phoneTel}>{CLINIC.phone}</a></p>
          <p class="mt-2">
            <a class="btn btn-primary" href={livHref} target="_blank" rel="noopener">Liv hospital profile</a>
          </p>
        </div>
        <div class="card">
          <h2 style="font-size:1.25rem;">Contact</h2>
          <ul class="mt-1" style="list-style:none;padding:0;">
            <li class="mt-1"><strong>Email:</strong> <a href={LINKS.email}>birkan.alayci@livhospital.com.tr</a></li>
            <li class="mt-1"><strong>Hospital:</strong> <a href={LINKS.liv} target="_blank" rel="noopener">Liv Hospital Vadistanbul</a></li>
            <li class="mt-1"><strong>Address:</strong> {CLINIC.addressEn}</li>
          </ul>
        </div>
      </div>

      <div class="mt-4">
        <h2>Location</h2>
        <div class="mt-2" style="border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);">
          <iframe
            src={CLINIC.mapEmbed}
            title="Liv Hospital Vadistanbul map location"
            width="100%"
            height="360"
            style="border:0;display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div class="note mt-4">
        <strong>Privacy (KVKK):</strong> see the
        <a href="/en/privacy/">privacy notice</a>.
      </div>
    </div>
  </section>
</Base>
