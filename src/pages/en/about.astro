---
import Base from '../../layouts/Base.astro';
import AppointmentBanner from '../../components/AppointmentBanner.astro';

const title = 'About — Birkan Alaycı, MD, Internal Medicine Specialist';
const description =
  'About Birkan Alaycı, MD: clinical approach in internal medicine, education and career, professional memberships.';
---

<Base {title} {description} lang="en" trHref="/hakkimda/" enHref="/en/about/">
  <section class="section">
    <div class="container prose">
      <p class="eyebrow">About</p>
      <h1>Birkan Alaycı, MD</h1>
      <p class="lead mt-2">
        Internal medicine specialist practicing at Liv Hospital Vadistanbul,
        Istanbul.
      </p>
      <p class="mt-3">
        My clinical work focuses on obesity, metabolic syndrome, diabetes, thyroid
        disorders and preventive health. It is shaped by evidence-based diagnostics,
        coordination of multimorbid patients, and pattern recognition that emerges
        from close engagement with each patient. My aim is to manage complex
        presentations in a clear, organized and structured way — applying the same
        structural rigor at the bedside and in the synthesis of evidence.
      </p>

      <h2 class="mt-4">Education &amp; career</h2>
      <ul class="timeline mt-2">
        <li><strong>Medical school</strong> — Dokuz Eylül University Faculty of Medicine (2018)</li>
        <li><strong>Internal Medicine residency</strong> — Şişli Hamidiye Etfal Training and Research Hospital, Istanbul (2023)</li>
        <li><strong>Currently</strong> — Liv Hospital Vadistanbul, Internal Medicine</li>
      </ul>

      <h2 class="mt-4">Professional memberships</h2>
      <ul class="mt-2">
        <li>American College of Physicians (ACP)</li>
        <li>Türk İç Hastalıkları Uzmanlık Derneği (TİHUD)</li>
        <li>Dahiliye Uzmanları Derneği (DAHUDER)</li>
      </ul>
    </div>
  </section>

  <AppointmentBanner lang="en" />
</Base>
