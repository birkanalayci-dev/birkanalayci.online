---
import Base from '../../layouts/Base.astro';
import AppointmentBanner from '../../components/AppointmentBanner.astro';
import KnowledgeFeed from '../../components/KnowledgeFeed.astro';

const title = 'Health Notes — Birkan Alaycı, MD, Internal Medicine';
const description =
  'Instead of long articles: health cards readable at a glance and short videos on diabetes, thyroid, blood pressure, metabolic health and check-ups — evidence-based, patient-friendly notes.';
---

<Base {title} {description} lang="en" trHref="/yazilar/" enHref="/en/writing/">
  <section class="section">
    <div class="container">
      <div class="prose">
        <p class="eyebrow">Health Notes</p>
        <h1>Short, clear health notes</h1>
        <p class="lead mt-2">
          Instead of long, technical articles — cards you can read at a glance and
          short videos with evidence-based information that’s useful in daily life.
        </p>
      </div>

      <div class="mt-4">
        <KnowledgeFeed lang="en" />
      </div>
    </div>
  </section>

  <AppointmentBanner lang="en" />
</Base>
