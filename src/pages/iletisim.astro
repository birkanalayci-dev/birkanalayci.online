---
import Base from '../layouts/Base.astro';
import { LINKS, PLACEHOLDER_LINKS } from '../data/site';

const title = 'İletişim & Randevu — Uzm. Dr. Birkan Alaycı, Liv Vadistanbul';
const description =
  'Uzm. Dr. Birkan Alaycı ile iletişim ve randevu. Liv Hospital Vadistanbul, İstanbul. Randevu talepleri Liv resmi kanalları üzerinden alınır.';

const livHref = PLACEHOLDER_LINKS.livAppointment !== '#' ? PLACEHOLDER_LINKS.livAppointment : LINKS.liv;
---

<Base {title} {description} lang="tr" trHref="/iletisim/" enHref="/en/contact/">
  <section class="section">
    <div class="container">
      <div class="prose">
        <p class="eyebrow">İletişim & randevu</p>
        <h1>Randevu ve iletişim</h1>
        <p class="lead mt-2">
          Muayene ve randevu talepleri Liv Hospital Vadistanbul’un resmi kanalları
          üzerinden alınmaktadır.
        </p>
      </div>

      <div class="grid grid-2 mt-4">
        <div class="card">
          <h2 style="font-size:1.25rem;">Randevu</h2>
          <p class="mt-1">
            Randevu için Liv Hospital’ın resmi kanalını kullanabilirsiniz.
          </p>
          <p class="mt-2">
            <a class="btn btn-primary" href={livHref} target="_blank" rel="noopener">
              Liv üzerinden randevu
            </a>
          </p>
          <p class="small muted mt-2">
            {/* [ONAY BEKLİYOR] Liv çağrı merkezi / doğrudan telefon — Birkan onaylamadan yazılmayacak */}
            Çağrı merkezi numarası: [ONAY BEKLİYOR — Birkan onaylayacak]
          </p>
          <p class="small muted mt-1">
            Online randevu sayfası: [ONAY BEKLİYOR — Liv randevu URL’si]
          </p>
        </div>

        <div class="card">
          <h2 style="font-size:1.25rem;">İletişim</h2>
          <ul class="mt-1" style="list-style:none;padding:0;">
            <li class="mt-1"><strong>E-posta:</strong> <a href={LINKS.email}>birkanalayci@gmail.com</a></li>
            <li class="mt-1"><strong>Hastane profili:</strong> <a href={LINKS.liv} target="_blank" rel="noopener">Liv Hospital Vadistanbul</a></li>
            <li class="mt-1"><strong>Konum:</strong> Liv Hospital Vadistanbul, İstanbul</li>
          </ul>
        </div>
      </div>

      <div class="mt-4">
        <h2>Konum</h2>
        {
          PLACEHOLDER_LINKS.mapEmbed ? (
            <div class="mt-2" style="border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);">
              <iframe
                src={PLACEHOLDER_LINKS.mapEmbed}
                title="Liv Hospital Vadistanbul harita"
                width="100%"
                height="360"
                style="border:0;display:block;"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
          ) : (
            <div class="note mt-2">
              Harita embed’i opsiyoneldir. [BİRKAN DOLDURACAK]: Google Maps embed
              URL’si <code>src/data/site.ts → PLACEHOLDER_LINKS.mapEmbed</code>
              alanına eklenince harita burada görünür.
              <span class="pending">Onay Bekliyor</span>
            </div>
          )
        }
      </div>

      <div class="note mt-4">
        <strong>KVKK:</strong> Kişisel verilerin korunmasına ilişkin aydınlatma
        metni için bkz.
        {/* [BİRKAN DOLDURACAK] KVKK aydınlatma metni linki */}
        <a href={PLACEHOLDER_LINKS.kvkk}>KVKK Aydınlatma Metni</a>
        <span class="pending">Bağlantı Bekliyor</span>
      </div>
    </div>
  </section>
</Base>
